{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/chat", "dest": "server.js" },
    { "src": "/health", "dest": "server.js" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.png)", "dest": "/$1" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/", "dest": "/index.html" }
  ]
}